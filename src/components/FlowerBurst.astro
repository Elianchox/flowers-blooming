       class="absolute bottom-12 left-1/2 -translate-x-1/2 text-white text-xl font-semibold"
       style="display: none; pointer-events: none; padding: 10px 28px; border-radius: 999px; background: rgba(120,30,60,0.55); backdrop-filter: blur(4px); text-shadow: 0 0 12px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.4);">
      Toca para continuar
    </p>
  </div>
</div>
