---
const VIDEO_ID = '-e1MUKFZNNE';
---

<div class="youtube-card">
  <div class="youtube-wrapper">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${VIDEO_ID}?autoplay=1&playsinline=1`}
      title="San Lucas — Kevin Kaarl"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
  <div class="tape-bar"></div>
</div>

<style>
  .youtube-card {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 3px 14px rgba(0, 0, 0, 0.15);
    background: #1a0e1e;
  }

  .youtube-wrapper {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%;
  }

  .youtube-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .tape-bar {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%) rotate(-1deg);
    width: 50px;
    height: 12px;
    background: rgba(200, 180, 160, 0.55);
    border-radius: 1px;
    pointer-events: none;
  }
</style>
