---
import Polaroid from "./Polaroid.astro";
import DigitalLetter from "./DigitalLetter.astro";
---

<div id="helloOverlay" class="scrapbook-page">
  <div class="tape-edge"></div>

  <div class="scrapbook-inner">
    <div class="caption-row" style="margin-top: 12px;">
      <div class="caption-tape caption-tape-left"></div>
      <span class="caption-text">"Mi flor favorita..."</span>
      <div class="caption-tape caption-tape-right"></div>
    </div>

    <div class="collage-row">
      <div class="collage-item" style="width:38%; z-index:3; rotate:-5deg;">
        <Polaroid src="/photos/photo_02.webp" alt="Foto 2" rotate={0} width="100%" tape="top-center" />
        <div class="flower-deco" style="top:-8px;left:-10px;rotate:-10deg;"></div>
        <div class="flower-deco" style="bottom:-6px;right:-8px;rotate:15deg;"></div>
      </div>
      <div class="collage-item" style="width:38%; z-index:2; margin-left:-12%; margin-top:28px; rotate:4deg;">
        <Polaroid src="/photos/photo_03.webp" alt="Foto 3" rotate={0} width="100%" />
        <div class="flower-deco" style="top:10px;right:-8px;rotate:25deg;"></div>
      </div>
      <div class="collage-item" style="width:38%; z-index:1; margin-left:-5%; margin-top:8px; rotate:-2deg;">
        <Polaroid src="/photos/photo_04.webp" alt="Foto 4" rotate={0} width="100%" />
        <div class="flower-deco" style="bottom:0;left:-6px;rotate:-20deg;"></div>
      </div>
    </div>

    <div class="section-handwritten">
      <Polaroid src="/photos/carta.webp" alt="Carta escrita a mano" rotate={1} width="90%" aspectRatio="1/1" tape="top-right" />
      <div class="flower-deco flower-deco--lg" style="top:-6px;left:10%;rotate:20deg;"></div>
      <div class="flower-deco flower-deco--lg" style="bottom:-6px;right:15%;rotate:-25deg;"></div>
      <div class="flower-deco flower-deco--lg" style="top:35%;right:-10px;rotate:40deg;"></div>
    </div>

    <div class="collage-row">
      <div class="collage-item" style="width:44%; z-index:3; rotate:-3deg;">
        <Polaroid src="/photos/photo_05.webp" alt="Foto 5" rotate={0} width="100%" aspectRatio="1/1" />
        <div class="flower-deco" style="top:-6px;right:-4px;rotate:8deg;"></div>
      </div>
      <div class="collage-item" style="width:46%; z-index:2; margin-left:-12%; margin-top:20px; rotate:5deg;">
        <Polaroid src="/photos/photo_01.webp" alt="Foto 1" rotate={0} width="100%" aspectRatio="1/1" />
        <div class="flower-deco" style="bottom:-4px;left:-8px;rotate:-15deg;"></div>
        <div class="flower-deco" style="top:-4px;right:-4px;rotate:30deg;"></div>
      </div>
      <div class="collage-final-bottom">
        <Polaroid src="/photos/photo_06.webp" alt="" rotate={-1} width="100%" />
        <div class="flower-deco" style="bottom:0;right:-6px;rotate:-5deg;"></div>
      </div>
    </div>

    <div class="collage-row" style="margin-top:4px;">
      <div class="collage-item" style="width:38%; z-index:3; rotate:3deg;">
        <Polaroid src="/photos/photo_08.webp" alt="" rotate={0} width="100%" />
        <div class="flower-deco" style="top:-6px;left:-6px;rotate:-12deg;"></div>
      </div>
      <div class="collage-item" style="width:38%; z-index:2; margin-left:-12%; margin-top:24px; rotate:-4deg;">
        <Polaroid src="/photos/photo_07.webp" alt="" rotate={0} width="100%" />
        <div class="flower-deco" style="top:8px;right:-6px;rotate:20deg;"></div>
      </div>
      <div class="collage-item" style="width:38%; z-index:1; margin-left:-5%; margin-top:10px; rotate:1deg;">
        <Polaroid src="/photos/photo_09.webp" alt="" rotate={0} width="100%" />
        <div class="flower-deco" style="bottom:-4px;left:-4px;rotate:-18deg;"></div>
      </div>
    </div>

    <div class="collage-row" style="margin-top:4px;">
      <div class="collage-item" style="width:40%; z-index:3; rotate:-2deg;">
        <Polaroid src="/photos/photo_10.webp" alt="" rotate={0} width="100%" />
        <div class="flower-deco" style="bottom:0;right:-6px;rotate:10deg;"></div>
      </div>
      <div class="collage-item" style="width:38%; z-index:2; margin-left:-12%; margin-top:18px; rotate:6deg;">
        <Polaroid src="/photos/photo_11.webp" alt="" rotate={0} width="100%" />
        <div class="flower-deco" style="top:-4px;left:-4px;rotate:-8deg;"></div>
      </div>
      <div class="collage-item" style="width:36%; z-index:4; margin:-45px auto 0; position:relative;">
        <Polaroid src="/photos/photo_12.webp" alt="" rotate={-3} width="100%" />
        <div class="flower-deco" style="top:6px;right:-6px;rotate:15deg;"></div>
      </div>
    </div>

    <DigitalLetter />
  </div>

  <div class="tape-edge"></div>
</div>

<style>
  .scrapbook-page {
    position: fixed;
    inset: 0;
    z-index: 20;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    display: none;
    flex-direction: column;
  }

  .tape-edge {
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      #f0d5c0 0px,
      #f0d5c0 16px,
      transparent 16px,
      transparent 22px
    );
    flex-shrink: 0;
  }

  .scrapbook-inner {
    max-width: 440px;
    margin: 0 auto;
    padding: 8px 16px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .caption-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 2px;
  }

  .caption-tape {
    width: 24px;
    height: 8px;
    background: rgba(200, 180, 160, 0.5);
    border-radius: 1px;
  }

  .caption-tape-left {
    rotate: -6deg;
  }

  .caption-tape-right {
    rotate: 5deg;
  }

  .caption-text {
    font-family: Georgia, serif;
    font-size: 13px;
    color: #6a4a3a;
    font-style: italic;
    padding: 2px 6px;
    background: rgba(250, 245, 240, 0.9);
  }

  .collage-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .collage-item {
    flex-shrink: 0;
    position: relative;
  }

  .section-handwritten {
    display: flex;
    justify-content: center;
    margin-top: 4px;
    position: relative;
  }

  .flower-deco {
    position: absolute;
    width: 24px;
    height: 21px;
    background-image: url('/flowers/flowers-grid.webp');
    background-repeat: no-repeat;
    background-position: -25px -0.5px;
    background-size: 74px 66px;
    pointer-events: none;
    z-index: 5;
  }

  .flower-deco--lg {
    width: 84px;
    height: 75px;
    background-position: -87px -1.4px;
    background-size: 258px 231px;
  }
</style>
