---
import Base from '../layouts/Base.astro';
import config from '../data/config.json';
import { FLOWER_LIST } from '../data/flowers';

const flowerSrcs = FLOWER_LIST.map((f) => f.src);
---

<Base>
  <fragment slot="head">
    <title>LockScreen</title>
  </fragment>

  <div class="relative min-h-screen flex items-center justify-center select-none overflow-hidden" style="background: url('/bgs/botanical-pattern.webp') center/cover no-repeat;">
    <div class="absolute inset-0 bg-linear-to-br from-pink-lightest/80 to-pink-light/80"></div>
    <div class="relative w-full text-center z-10">
      <div class="text-5xl mb-2">🌸</div>
      <h1 class="text-pink-primary text-2xl font-semibold mb-1">Ingresa tu PIN</h1>
      <p class="text-pink-medium text-sm mb-7">4 dígitos</p>

      <div class="flex justify-center gap-3.5 mb-8" id="pinDots">
        <div class="w-4.5 h-4.5 rounded-full border-[2.5px] border-pink-medium bg-white transition-all duration-200"></div>
        <div class="w-4.5 h-4.5 rounded-full border-[2.5px] border-pink-medium bg-white transition-all duration-200"></div>
        <div class="w-4.5 h-4.5 rounded-full border-[2.5px] border-pink-medium bg-white transition-all duration-200"></div>
        <div class="w-4.5 h-4.5 rounded-full border-[2.5px] border-pink-medium bg-white transition-all duration-200"></div>
      </div>

      <div class="w-full grid grid-cols-3 gap-3 max-w-65 mx-auto" id="keypad">
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="1">1</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="2">2</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="3">3</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="4">4</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="5">5</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="6">6</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="7">7</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="8">8</button>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="9">9</button>
        <div></div>
        <button class="key rounded-xl py-4 bg-pink-light text-pink-primary text-2xl font-semibold cursor-pointer border border-pink-border transition-transform duration-100 active:scale-95 active:bg-pink-border" data-digit="0">0</button>
        <button class="key rounded-xl py-4 bg-lavender-light text-lavender-dark text-2xl font-semibold cursor-pointer border border-transparent transition-transform duration-100 active:scale-95 active:bg-[#dcc0d0]" id="deleteKey">⌫</button>
      </div>

      <p class="text-error text-sm mt-6 hidden" id="errorMsg">PIN incorrecto</p>
    </div>
  </div>

  <script define:vars={{ correctPin: config.pin }}>
    const CORRECT_PIN = correctPin;

    let pin = '';
    const dots = document.querySelectorAll('#pinDots > div');
    const errorMsg = document.getElementById('errorMsg');
    const keypad = document.getElementById('keypad');

    function updateDots() {
      dots.forEach((dot, i) => {
        const filled = i < pin.length;
        dot.classList.toggle('bg-white', !filled);
        dot.classList.toggle('bg-pink-primary', filled);
        dot.classList.toggle('border-pink-primary', filled);
      });
    }

    function showError() {
      errorMsg.classList.remove('hidden');
      document.getElementById('pinDots').classList.add('animate-shake');
      setTimeout(() => {
        document.getElementById('pinDots').classList.remove('animate-shake');
      }, 400);
      setTimeout(() => {
        pin = '';
        updateDots();
        errorMsg.classList.add('hidden');
      }, 1500);
    }

    keypad.addEventListener('click', (e) => {
      const key = e.target.closest('.key');
      if (!key) return;

      if (key.id === 'deleteKey') {
        if (pin.length > 0) {
          pin = pin.slice(0, -1);
          updateDots();
        }
        return;
      }

      if (pin.length >= 4) return;

      const digit = key.dataset.digit;
      if (digit === undefined) return;

      pin += digit;
      updateDots();

      if (pin.length === 4) {
        if (pin === CORRECT_PIN) {
          sessionStorage.setItem('unlocked', 'true');
          window.location.href = '/letter';
        } else {
          showError();
        }
      }
    });
  </script>

  <script define:vars={{ flowerSrcs }}>
    const FLOWER_COUNT = 14;
    const MIN_SIZE = 60;
    const MAX_SIZE = 120;

    function random(min, max) {
      return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function generatePositions(count) {
      const perEdge = Math.floor(count / 4);
      const remainder = count % 4;

      const edgeCounts = [
        perEdge + (remainder > 0 ? 1 : 0),
        perEdge,
        perEdge + (remainder > 1 ? 1 : 0),
        perEdge,
      ];

      const margin = 3;
      const positions = [];

      const edges = [
        { side: 'top', axis: 'left' },
        { side: 'right', axis: 'top' },
        { side: 'bottom', axis: 'left' },
        { side: 'left', axis: 'top' },
      ];

      edges.forEach(({ side, axis }, i) => {
        const n = edgeCounts[i];
        for (let j = 0; j < n; j++) {
          const pos = {};
          if (side === 'top') {
            pos.top = `${margin}%`;
            pos.left = `${5 + (j + 0.5) * (90 / n)}%`;
          } else if (side === 'bottom') {
            pos.bottom = `${margin}%`;
            pos.left = `${5 + (j + 0.5) * (90 / n)}%`;
          } else if (side === 'right') {
            pos.right = `${margin}%`;
            pos.top = `${5 + (j + 0.5) * (90 / n)}%`;
          } else {
            pos.left = `${margin}%`;
            pos.top = `${5 + (j + 0.5) * (90 / n)}%`;
          }
          positions.push(pos);
        }
      });

      return positions;
    }

    const container = document.createElement('div');
    container.id = 'flower-decoration';
    container.style.cssText = [
      'position: fixed',
      'inset: 0',
      'z-index: 0',
      'pointer-events: none',
      'overflow: hidden',
    ].join(';');
    document.body.appendChild(container);

    const positions = generatePositions(FLOWER_COUNT);

    positions.forEach((pos) => {
      const img = document.createElement('img');
      img.src = flowerSrcs[random(0, flowerSrcs.length - 1)];
      img.alt = '';
      img.style.width = `${random(MIN_SIZE, MAX_SIZE)}px`;
      img.style.height = 'auto';
      img.style.position = 'absolute';
      img.style.willChange = 'transform';
      img.style.filter = 'drop-shadow(0 4px 8px rgba(0, 0, 0, 0.15))';

      Object.assign(img.style, pos);

      container.appendChild(img);
    });
  </script>
</Base>
