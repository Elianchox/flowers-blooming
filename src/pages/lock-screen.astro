---
import config from '../data/config.json';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>LockScreen</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #fff5f8 0%, #fce4ec 100%);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      -webkit-user-select: none;
      user-select: none;
    }
    .container { text-align: center; }
    .icon { font-size: 3rem; margin-bottom: 0.5rem; }
    .title {
      color: #d4818c;
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }
    .subtitle {
      color: #e8a0b0;
      font-size: 0.9rem;
      margin-bottom: 1.8rem;
    }
    .pin-dots {
      display: flex;
      justify-content: center;
      gap: 14px;
      margin-bottom: 2rem;
    }
    .pin-dot {
      width: 18px; height: 18px;
      border-radius: 50%;
      border: 2.5px solid #f0b4c4;
      background: #fff;
      transition: background 0.2s, border-color 0.2s;
    }
    .pin-dot.filled {
      background: #d4818c;
      border-color: #d4818c;
    }
    .keypad {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      max-width: 260px;
      margin: 0 auto;
    }
    .key {
      background: #fce4ec;
      border: 1px solid #f8d0dc;
      border-radius: 14px;
      padding: 1rem;
      font-size: 1.5rem;
      color: #d4818c;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.1s, background 0.15s;
    }
    .key:active {
      transform: scale(0.95);
      background: #f8d0dc;
    }
    .key-delete {
      background: #e8d5e0;
      border-color: #dcc0d0;
      color: #b08090;
    }
    .key-delete:active {
      background: #dcc0d0;
    }
    .key-empty { visibility: hidden; }
    .error-msg {
      margin-top: 1.5rem;
      color: #e57373;
      font-size: 0.9rem;
      display: none;
    }
    .error-msg.visible { display: block; }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-8px); }
      40%, 80% { transform: translateX(8px); }
    }
    .shake { animation: shake 0.4s ease; }
  </style>
</head>
<body>
  <div class="container">
    <div class="icon">🌸</div>
    <h1 class="title">Ingresa tu PIN</h1>
    <p class="subtitle">4 dígitos</p>

    <div class="pin-dots" id="pinDots">
      <div class="pin-dot"></div>
      <div class="pin-dot"></div>
      <div class="pin-dot"></div>
      <div class="pin-dot"></div>
    </div>

    <div class="keypad" id="keypad">
      <button class="key" data-digit="1">1</button>
      <button class="key" data-digit="2">2</button>
      <button class="key" data-digit="3">3</button>
      <button class="key" data-digit="4">4</button>
      <button class="key" data-digit="5">5</button>
      <button class="key" data-digit="6">6</button>
      <button class="key" data-digit="7">7</button>
      <button class="key" data-digit="8">8</button>
      <button class="key" data-digit="9">9</button>
      <div class="key key-empty"></div>
      <button class="key" data-digit="0">0</button>
      <button class="key key-delete" id="deleteKey">⌫</button>
    </div>

    <p class="error-msg" id="errorMsg">PIN incorrecto</p>
  </div>

  <script define:vars={{ correctPin: config.pin }}>
    const CORRECT_PIN = correctPin;

    let pin = '';
    const dots = document.querySelectorAll('.pin-dot');
    const errorMsg = document.getElementById('errorMsg');
    const keypad = document.getElementById('keypad');

    function updateDots() {
      dots.forEach((dot, i) => {
        dot.classList.toggle('filled', i < pin.length);
      });
    }

    function showError() {
      errorMsg.classList.add('visible');
      document.querySelector('.pin-dots').classList.add('shake');
      setTimeout(() => {
        document.querySelector('.pin-dots').classList.remove('shake');
      }, 400);
      setTimeout(() => {
        pin = '';
        updateDots();
        errorMsg.classList.remove('visible');
      }, 1500);
    }

    keypad.addEventListener('click', (e) => {
      const key = e.target.closest('.key');
      if (!key) return;

      if (key.id === 'deleteKey') {
        if (pin.length > 0) {
          pin = pin.slice(0, -1);
          updateDots();
        }
        return;
      }

      if (pin.length >= 4) return;

      const digit = key.dataset.digit;
      if (digit === undefined) return;

      pin += digit;
      updateDots();

      if (pin.length === 4) {
        if (pin === CORRECT_PIN) {
          sessionStorage.setItem('unlocked', 'true');
          window.location.href = '/letter';
        } else {
          showError();
        }
      }
    });
  </script>
</body>
</html>
