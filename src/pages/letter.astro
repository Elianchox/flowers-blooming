---
import Base from '../layouts/Base.astro';
import Envelope from '../components/Envelope.astro';
import FlowerBurst from '../components/FlowerBurst.astro';
import HelloOverlay from '../components/HelloOverlay.astro';
import { OBJECT_LIST } from '../data/objects';
import { FLOWER_LIST } from '../data/flowers';

const closedEnvelope = OBJECT_LIST.find((o) => o.name === 'envelope-closed.webp');
const openedEnvelope = OBJECT_LIST.find((o) => o.name === 'envelope-opened.webp');
const flowerIndices = FLOWER_LIST.map((f) => f.spriteIndex);
---

<Base>
  <fragment slot="head">
    <title>Carta</title>
    <script>
      (function() {
        if (sessionStorage.getItem('unlocked')) {
          document.documentElement.style.display = '';
        } else {
          window.location.replace('/lock-screen');
        }
      })();
    </script>
  </fragment>
  <fragment>
    <div id="app" class="relative min-h-screen flex items-center justify-center select-none overflow-hidden"
         style="background: url('/bgs/botanical-pattern.webp') center/cover no-repeat;">
      <div class="absolute inset-0 bg-linear-to-br from-pink-lightest/80 to-pink-light/80"></div>

      <Envelope closedSrc={closedEnvelope?.src ?? ''} openedSrc={openedEnvelope?.src ?? ''} />
      <FlowerBurst />
      <HelloOverlay />
    </div>
  </fragment>
</Base>

<script define:vars={{ flowerIndices }}>
  window.__flowerIndices = flowerIndices;
</script>

<script>
import { generateFlowerPositions, createFlowerElements, triggerBurst } from '../scripts/burst-engine';

  const FLOWER_SIZE = 200;
  const BURST_DURATION = 1000;
  const flowerIndices = (window as unknown as { __flowerIndices: number[] }).__flowerIndices;

  let isOpening = false;
  let isOpen = false;
  let flowersCreated = false;
  let flowerElements: HTMLElement[] = [];
  const flowerContainer = document.getElementById('flowerContainer')!;
  const dismissBackdrop = document.getElementById('dismissBackdrop')!;
  const envClosed = document.getElementById('envClosed') as HTMLImageElement;
  const envOpened = document.getElementById('envOpened') as HTMLImageElement;
  const tapText = document.getElementById('tapText')!;
  const helloOverlay = document.getElementById('helloOverlay')!;

  function handleOpen() {
    if (isOpening || isOpen) return;
    isOpening = true;

    const envRect = envClosed.getBoundingClientRect();
    const burstCenterX = envRect.left + envRect.width / 2;
    const burstCenterY = envRect.top + envRect.height / 2;

    envClosed.classList.remove('animate-float-vertical');
    void envClosed.offsetWidth;
    envClosed.style.transition = 'transform 0.3s ease, opacity 0.2s ease';
    envClosed.style.transform = 'rotate(-10deg)';

    setTimeout(() => {
      envClosed.style.opacity = '0';
      envOpened.classList.remove('hidden');
      envOpened.style.transition = 'opacity 0.2s ease';
      envOpened.style.opacity = '1';
      tapText.style.transition = 'opacity 0.2s ease';
      tapText.style.opacity = '0';

      if (!flowersCreated) {
        const positions = generateFlowerPositions(FLOWER_SIZE, window.innerWidth, window.innerHeight);
        flowerElements = createFlowerElements(positions, flowerContainer, { x: burstCenterX, y: burstCenterY }, flowerIndices, FLOWER_SIZE);
        flowersCreated = true;
      }
      flowerContainer.style.display = 'block';

      setTimeout(() => {
        triggerBurst(flowerElements, BURST_DURATION);

        setTimeout(() => {
          envOpened.style.transition = 'opacity 0.3s ease';
          envOpened.style.opacity = '0';
        }, 400);

        const totalBurstTime = BURST_DURATION + 1000 + 200;
        setTimeout(() => {
          isOpen = true;
          isOpening = false;
          dismissBackdrop.style.pointerEvents = 'auto';
          const tapText = document.getElementById('tapToContinue')!;
          tapText.style.display = 'block';
          tapText.style.opacity = '0';
          tapText.offsetHeight;
          tapText.style.transition = 'opacity 0.6s ease';
          tapText.style.opacity = '1';
          tapText.classList.add('animate-pulse-opacity');
        }, totalBurstTime);
      }, 300);
    }, 300);
  }

  document.getElementById('envelopeSection')!.addEventListener('click', () => {
    if (!isOpen && !isOpening) {
      handleOpen();
    }
  });

  dismissBackdrop.addEventListener('click', () => {
    if (!isOpen || isOpening) return;

    const centerX = window.innerWidth / 2;
    const ANIM_DURATION = 700;
    const MAX_STAGGER = 250;

    flowerElements.forEach((el) => {
      const flowerX = parseFloat(el.style.left) + parseFloat(el.style.width) / 2;
      const distFromCenter = Math.abs(flowerX - centerX);
      const delay = (distFromCenter / centerX) * MAX_STAGGER;
      const isLeft = flowerX < centerX;

      el.style.animation = '';
      el.style.transition = `transform ${ANIM_DURATION}ms cubic-bezier(0.87, 0, 0.13, 1) ${delay}ms, opacity ${ANIM_DURATION * 0.4}ms ease ${delay}ms`;
      el.style.transform = `translateX(${isLeft ? '-150vw' : '150vw'})`;
      el.style.opacity = '0';
    });

    const totalDuration = ANIM_DURATION + MAX_STAGGER;

    flowerContainer.style.transition = `opacity 0.4s ease ${totalDuration - 300}ms`;
    flowerContainer.style.opacity = '0';

    setTimeout(() => {
      flowerContainer.style.display = 'none';
      helloOverlay.style.display = 'flex';
      helloOverlay.style.opacity = '0';
      helloOverlay.offsetHeight;
      helloOverlay.style.transition = 'opacity 0.5s ease';
      helloOverlay.style.opacity = '1';
    }, totalDuration + 100);
  });
</script>
